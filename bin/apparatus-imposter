#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
DIST="$REPO_DIR/apps/apparatus/dist/imposter/index.js"
if [[ ! -f "$DIST" ]]; then
  echo "apparatus-imposter: build not found at apps/apparatus/dist/imposter/index.js" >&2
  echo "Run: pnpm build" >&2
  exit 2
fi
exec node "$DIST" "$@"
